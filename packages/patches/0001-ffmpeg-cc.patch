+static void cc608_store_text(char **dst, const char *src)
+{
+    char *tmp = NULL;
+
+    if (src && src[0]) {
+        tmp = av_strdup(src);
+        if (!tmp)
+            return;
+    }
+
+    av_freep(dst);
+    *dst = tmp;
+}
+
+static int cc608_is_prefix_growth(const char *prev, const char *cur)
+{
+    size_t prev_len, cur_len;
+
+    if (!prev || !cur)
+        return 0;
+
+    prev_len = strlen(prev);
+    cur_len = strlen(cur);
+
+    if (prev_len < 2 || cur_len <= prev_len)
+        return 0;
+
+    return strncmp(prev, cur, prev_len) == 0;
+}
