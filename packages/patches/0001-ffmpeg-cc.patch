+static int cc608_visible_text_score(const char *s)
+{
+    int score = 0;
+    int in_tag = 0;
+
+    if (!s)
+        return 0;
+
+    for (; *s; s++) {
+        if (in_tag) {
+            if (*s == '}')
+                in_tag = 0;
+            continue;
+        }
+
+        if (*s == '{') {
+            in_tag = 1;
+            continue;
+        }
+
+        if (*s == '\') {
+            if (s[1] == 'N' || s[1] == 'h') {
+                s++;
+                continue;
+            }
+        }
+
+        if (*s == ' ' || *s == '
+' || *s == '
+' || *s == '	')
+            continue;
+
+        score++;
+    }
+
+    return score;
+}
+
+static void cc608_visible_text_stats(const char *s, int *letters, int *vowels, int *spaces)
+{
+    int in_tag = 0;
+
+    *letters = 0;
+    *vowels  = 0;
+    *spaces  = 0;
+
+    if (!s)
+        return;
+
+    for (; *s; s++) {
+        unsigned char ch = *s;
+
+        if (in_tag) {
+            if (ch == '}')
+                in_tag = 0;
+            continue;
+        }
+
+        if (ch == '{') {
+            in_tag = 1;
+            continue;
+        }
+
+        if (ch == '\') {
+            if (s[1] == 'N' || s[1] == 'h') {
+                if (s[1] == 'N')
+                    (*spaces)++;
+                s++;
+                continue;
+            }
+        }
+
+        if (ch == ' ') {
+            (*spaces)++;
+            continue;
+        }
+
+        if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+            (*letters)++;
+            switch (ch | 32) {
+            case 'a':
+            case 'e':
+            case 'i':
+            case 'o':
+            case 'u':
+                (*vowels)++;
+                break;
+            }
+        }
+    }
+}
+
+static int cc608_should_emit_realtime(const char *s)
+{
+    int score;
+    int letters, vowels, spaces;
+
+    if (!s || !s[0])
+        return 0;
+
+    score = cc608_visible_text_score(s);
+    if (score < 10)
+        return 0;
+
+    cc608_visible_text_stats(s, &letters, &vowels, &spaces);
+
+    /*
+     * Reject obvious warm-up garbage such as "NNCPANNCNN":
+     * long consonant-heavy text with no spaces is very unlikely
+     * to be a real subtitle line.
+     */
+    if (letters > 0 && spaces == 0 && vowels * 4 < letters && score < 20)
+        return 0;
+
+    return 1;
+}
