+static int cc608_visible_text_score(const char *s)
+{
+    int score = 0;
+    int in_tag = 0;
+
+    if (!s)
+        return 0;
+
+    for (; *s; s++) {
+        if (in_tag) {
+            if (*s == '}')
+                in_tag = 0;
+            continue;
+        }
+
+        if (*s == '{') {
+            in_tag = 1;
+            continue;
+        }
+
+        if (*s == '\\') {
+            if (s[1] == 'N' || s[1] == 'h') {
+                s++;
+                continue;
+            }
+        }
+
+        if (*s == ' ' || *s == '\r' || *s == '\n' || *s == '\t')
+            continue;
+
+        score++;
+    }
+
+    return score;
+}
+
+static int cc608_should_emit_realtime(const char *s)
+{
+    int score = cc608_visible_text_score(s);
+
+    if (!s || !s[0])
+        return 0;
+
+    /* Suppress empty / tiny incremental paints like "EX", "TR", quotes, etc. */
+    if (score < 8)
+        return 0;
+
+    return 1;
+}
+
+static int cc608_should_emit_text(const char *s)
+{
+    return cc608_visible_text_score(s) > 0;
+}
+
+static int cc608_same_text(const char *a, const char *b)
+{
+    if (!a || !b)
+        return 0;
+    return strcmp(a, b) == 0;
+}
+
+static int cc608_store_text(char **dst, const char *src)
+{
+    char *tmp;
+
+    if (!src)
+        src = "";
+
+    tmp = av_strdup(src);
+    if (!tmp)
+        return AVERROR(ENOMEM);
+
+    av_freep(dst);
+    *dst = tmp;
+    return 0;
+}
